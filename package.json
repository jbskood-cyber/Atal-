{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc --noEmit && vite build",
    "start": "vite preview --host 0.0.0.0 --port 3000",
    "typecheck": "tsc --noEmit",
    "test:core:compile": "rm -rf .tmp/core-tests && tsc -p tests/tsconfig.core.json",
    "test": "npm run test:core:compile && node --test tests/*.test.mjs",
    "audit:ai-capabilities": "npm run test:core:compile && node scripts/atal-ai/generate-capability-report.mjs",
    "quality": "npm run typecheck && npm test && npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@fontsource/poppins": "^5.2.7",
    "@hookform/resolvers": "^5.2.1",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "^6.2.3"
  }
}
